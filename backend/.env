# AI Career Assistant - Environment Variables
# Copy this file to .env and update with your AWS credentials

# AWS Bedrock Configuration (REQUIRED)
# These are used for AI interview question generation
AIOS_BEDROCK_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=your_token_here
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Alternative: Standard AWS credentials via ~/.aws/credentials
# Remove the above 3 lines if using standard AWS CLI credentials

# Bedrock Model ID (optional, defaults to Claude 3 Haiku)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Flask Configuration
FLASK_ENV=production
FLASK_PORT=5000

# CORS Origins - update with your Vercel frontend URL after deployment
ALLOWED_ORIGINS=https://ai-career-assistant.vercel.app,http://localhost:5173,http://localhost:3000
