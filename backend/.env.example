# AI Career Assistant - Environment Variables
# Copy this file to .env and fill in your values

# AWS Bedrock Configuration (REQUIRED for AI features)
# Option 1: Use AWS CLI credentials (recommended)
#   Run: aws configure
#   This creates ~/.aws/credentials automatically

# Option 2: Set credentials via environment variables
AIOS_BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_if_available

# Bedrock Model ID (optional)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Flask Configuration
FLASK_ENV=production
FLASK_PORT=5000

# CORS Origins
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,http://localhost:5173
